FLIGHT_DATA_PROVIDER=flightaware
FLIGHTAWARE_API_KEY=replace-with-your-flightaware-key
AERODATABOX_MARKETPLACE=apimarket
AERODATABOX_API_KEY=replace-with-your-aerodatabox-key
# Recommended for AeroDataBox 24,000-unit plans with a 05:00-22:00 local refresh window: 360 seconds keeps normal board refreshes at 6 minutes.
# AERODATABOX_BASE_URL=https://prod.api.market/api/v1/aedbx/aerodatabox
# AERODATABOX_RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
FLIGHT_BOARD_REFRESH_SECONDS=360
FLIGHT_DATA_CACHE_SECONDS=360
FLIGHT_REFRESH_START_TIME=05:00
FLIGHT_REFRESH_END_TIME=22:00
FLIGHT_DB_PATH=data/fr_dashboard.sqlite3
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-before-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
# ADMIN_PASSWORD_HASH=pbkdf2:sha256:...
AIRPORT_TIMEZONE=Australia/Hobart
FLIGHT_COMPLETED_RETENTION_MINUTES=30
