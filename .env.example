APP_ROLE=server
FLIGHT_DATA_PROVIDER=flightaware
FLIGHTAWARE_API_KEY=replace-with-your-flightaware-key
AERODATABOX_MARKETPLACE=apimarket
AERODATABOX_API_KEY=replace-with-your-aerodatabox-key
# Recommended split for kiosk displays on API-limited plans:
# - FLIGHT_BOARD_REFRESH_SECONDS controls how often the browser refreshes from your local Flask app.
# - FLIGHT_DATA_CACHE_SECONDS controls how often the server is allowed to hit the external provider.
# AERODATABOX_BASE_URL=https://prod.api.market/api/v1/aedbx/aerodatabox
# AERODATABOX_RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
FLIGHT_BOARD_REFRESH_SECONDS=30
FLIGHT_DATA_CACHE_SECONDS=360
# Optional: force a full browser reload for kiosk watchdog behavior. Set 0 to disable.
BROWSER_HARD_REFRESH_SECONDS=1800
FLIGHT_REFRESH_START_TIME=05:00
FLIGHT_REFRESH_END_TIME=22:00
FLIGHT_DB_PATH=data/fr_dashboard.sqlite3
CLIENT_CACHE_DB_PATH=data/client_cache.sqlite3
CLIENT_SYNC_SECONDS=30
CLIENT_AUTH_MAX_SKEW_SECONDS=60
SERVER_BASE_URL=https://example.your-domain.com
CLIENT_ID=replace-with-client-id
CLIENT_SECRET=replace-with-client-secret
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-before-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
# ADMIN_PASSWORD_HASH=pbkdf2:sha256:...
AIRPORT_TIMEZONE=Australia/Hobart
FLIGHT_COMPLETED_RETENTION_MINUTES=30
